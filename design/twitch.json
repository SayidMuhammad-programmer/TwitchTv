{
  "designSystem": {
    "name": "Mobile Chat Interface Design System",
    "version": "1.0.0",
    "description": "Design system extracted from Twitch-style mobile chat interface",
    
    "colorPalette": {
      "primary": {
        "background": "#000000",
        "backgroundSecondary": "#1a1a1a",
        "backgroundTertiary": "#2d2d2d",
        "surface": "#333333"
      },
      "accent": {
        "purple": "#9146FF",
        "red": "#E91916",
        "redSecondary": "#FF4444"
      },
      "text": {
        "primary": "#FFFFFF",
        "secondary": "#CCCCCC",
        "muted": "#999999",
        "disabled": "#666666"
      },
      "status": {
        "online": "#00FF00",
        "offline": "#999999",
        "warning": "#FFB800",
        "error": "#E91916"
      },
      "ui": {
        "border": "#333333",
        "borderActive": "#9146FF",
        "shadow": "rgba(0, 0, 0, 0.5)",
        "overlay": "rgba(0, 0, 0, 0.8)"
      }
    },

    "typography": {
      "fontFamily": {
        "primary": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "secondary": "SF Pro Display, Helvetica, Arial, sans-serif"
      },
      "fontSize": {
        "xs": "10px",
        "sm": "12px",
        "base": "14px",
        "md": "16px",
        "lg": "18px",
        "xl": "20px",
        "2xl": "24px"
      },
      "fontWeight": {
        "light": 300,
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "lineHeight": {
        "tight": 1.2,
        "normal": 1.4,
        "relaxed": 1.6,
        "loose": 1.8
      },
      "hierarchy": {
        "statusBarText": {
          "fontSize": "14px",
          "fontWeight": 600,
          "color": "#FFFFFF"
        },
        "tabText": {
          "fontSize": "16px",
          "fontWeight": 500,
          "color": "#CCCCCC"
        },
        "tabTextActive": {
          "fontSize": "16px",
          "fontWeight": 600,
          "color": "#FFFFFF"
        },
        "chatMessage": {
          "fontSize": "14px",
          "fontWeight": 400,
          "color": "#FFFFFF",
          "lineHeight": 1.4
        },
        "username": {
          "fontSize": "14px",
          "fontWeight": 600,
          "color": "#FFFFFF"
        },
        "inputPlaceholder": {
          "fontSize": "16px",
          "fontWeight": 400,
          "color": "#999999"
        }
      }
    },

    "spacing": {
      "unit": 4,
      "scale": {
        "xs": "4px",
        "sm": "8px",
        "md": "12px",
        "base": "16px",
        "lg": "20px",
        "xl": "24px",
        "2xl": "32px",
        "3xl": "40px",
        "4xl": "48px"
      },
      "padding": {
        "statusBar": {
          "horizontal": "16px",
          "vertical": "8px"
        },
        "tabNavigation": {
          "horizontal": "20px",
          "vertical": "12px"
        },
        "chatContainer": {
          "horizontal": "16px",
          "vertical": "8px"
        },
        "chatMessage": {
          "horizontal": "16px",
          "vertical": "8px"
        },
        "inputArea": {
          "horizontal": "16px",
          "vertical": "12px"
        },
        "bottomNavigation": {
          "horizontal": "16px",
          "vertical": "8px"
        }
      },
      "margin": {
        "messageSpacing": "8px",
        "tabSpacing": "24px",
        "sectionSpacing": "16px"
      }
    },

    "layout": {
      "grid": {
        "columns": 12,
        "gutter": "16px",
        "containerMaxWidth": "100%"
      },
      "breakpoints": {
        "mobile": "375px",
        "tablet": "768px",
        "desktop": "1024px"
      },
      "structure": {
        "statusBarHeight": "44px",
        "tabNavigationHeight": "48px",
        "bottomNavigationHeight": "83px",
        "inputAreaHeight": "56px",
        "chatAreaMinHeight": "calc(100vh - 231px)"
      }
    },

    "components": {
      "buttons": {
        "primary": {
          "backgroundColor": "#9146FF",
          "color": "#FFFFFF",
          "borderRadius": "8px",
          "padding": "12px 20px",
          "fontSize": "16px",
          "fontWeight": 600,
          "border": "none"
        },
        "secondary": {
          "backgroundColor": "transparent",
          "color": "#CCCCCC",
          "borderRadius": "8px",
          "padding": "12px 20px",
          "fontSize": "16px",
          "fontWeight": 500,
          "border": "1px solid #333333"
        },
        "icon": {
          "backgroundColor": "transparent",
          "color": "#CCCCCC",
          "borderRadius": "50%",
          "padding": "8px",
          "border": "none",
          "minWidth": "40px",
          "minHeight": "40px"
        }
      },
      "inputs": {
        "chatInput": {
          "backgroundColor": "#2d2d2d",
          "color": "#FFFFFF",
          "borderRadius": "20px",
          "padding": "12px 48px 12px 16px",
          "fontSize": "16px",
          "border": "1px solid #333333",
          "outline": "none"
        }
      },
      "navigation": {
        "tab": {
          "inactive": {
            "color": "#CCCCCC",
            "borderBottom": "2px solid transparent",
            "padding": "12px 0"
          },
          "active": {
            "color": "#9146FF",
            "borderBottom": "2px solid #9146FF",
            "padding": "12px 0"
          }
        },
        "bottomNavItem": {
          "inactive": {
            "color": "#666666",
            "fontSize": "10px"
          },
          "active": {
            "color": "#9146FF",
            "fontSize": "10px"
          }
        }
      },
      "chat": {
        "message": {
          "backgroundColor": "transparent",
          "padding": "8px 16px",
          "borderRadius": "0px",
          "marginBottom": "4px"
        },
        "messageIcon": {
          "width": "16px",
          "height": "16px",
          "marginRight": "8px",
          "color": "#E91916"
        }
      },
      "badges": {
        "notification": {
          "backgroundColor": "#E91916",
          "color": "#FFFFFF",
          "borderRadius": "50%",
          "minWidth": "20px",
          "height": "20px",
          "fontSize": "12px",
          "fontWeight": 600,
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "center"
        },
        "new": {
          "backgroundColor": "transparent",
          "color": "#E91916",
          "fontSize": "14px",
          "fontWeight": 600
        }
      }
    },

    "effects": {
      "borderRadius": {
        "none": "0px",
        "sm": "4px",
        "base": "8px",
        "md": "12px",
        "lg": "16px",
        "xl": "20px",
        "full": "9999px"
      },
      "shadows": {
        "none": "none",
        "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "base": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)",
        "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
        "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
        "statusBar": "0 2px 10px rgba(0, 0, 0, 0.3)"
      },
      "gradients": {
        "statusBar": "linear-gradient(180deg, #8B4513 0%, #654321 50%, #3E2723 100%)",
        "darkOverlay": "linear-gradient(180deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.9) 100%)"
      },
      "transitions": {
        "fast": "150ms ease",
        "normal": "300ms ease",
        "slow": "500ms ease"
      }
    },

    "states": {
      "interactive": {
        "default": {
          "opacity": 1,
          "transform": "scale(1)"
        },
        "hover": {
          "opacity": 0.8,
          "transform": "scale(1.02)",
          "transition": "150ms ease"
        },
        "active": {
          "opacity": 0.6,
          "transform": "scale(0.98)",
          "transition": "100ms ease"
        },
        "disabled": {
          "opacity": 0.4,
          "cursor": "not-allowed"
        }
      }
    },

    "accessibility": {
      "minimumTouchTarget": "44px",
      "focusIndicator": {
        "outline": "2px solid #9146FF",
        "outlineOffset": "2px"
      },
      "contrastRatios": {
        "primaryText": "AAA",
        "secondaryText": "AA",
        "interactiveElements": "AA"
      }
    },

    "implementation": {
      "notes": [
        "Status bar uses system-provided styling on mobile devices",
        "Bottom navigation includes safe area insets for modern mobile devices",
        "Chat messages should support infinite scroll with virtualization",
        "Icon buttons require hover states for desktop interactions",
        "Input field should expand/contract based on content length",
        "Navigation tabs should support swipe gestures on mobile"
      ],
      "responsive": {
        "mobile": {
          "maxWidth": "100%",
          "padding": "0 16px"
        },
        "tablet": {
          "maxWidth": "768px",
          "padding": "0 24px"
        },
        "desktop": {
          "maxWidth": "375px",
          "margin": "0 auto",
          "boxShadow": "0 0 20px rgba(0,0,0,0.3)"
        }
      }
    }
  }
}
